# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (画像生成)
OPENAI_API_KEY=sk-...
# 画像生成モデル（DALL-E 3は廃止済み。gpt-image系を指定）
IMAGE_MODEL=gpt-image-2
# 画質: low / medium / high（挿絵の既定。スライドは文字品質のため自動でhigh）
IMAGE_QUALITY=medium

# Google Cloud / Firebase
GCP_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Application
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# 本番ではフロントのURLをカンマ区切りで指定（例: https://aiaruku.com）
ALLOWED_ORIGINS=*

# 組織情報（文章生成プロンプトに使用）
ORG_NAME=教育機関
ORG_DESCRIPTION=プログラミング教室
BLOG_TONE=フレンドリーで親しみやすい
BLOG_CTA=ぜひお気軽にお問い合わせください
CF_PROJECT_NAME=プログラミング教室プロジェクト
CF_BACKGROUND=子どもたちの学習支援
CF_NOTES=クラウドファンディングで支援してください
